      <aliases enabled='yes' />
      <column caption='AD Email' datatype='string' name='[ADEmail]' role='dimension' type='nominal' />
      <column caption='Business Unit' datatype='string' name='[BusinessUnit]' role='dimension' type='nominal' />
      <column caption=' Is Active' datatype='boolean' name='[Calculation_2669902783520769]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='ISNULL([ExitDate])' />
      </column>
      <column caption=' Tenure (Years)' datatype='integer' name='[Calculation_2669902783688706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [StartDate], IFNULL([ExitDate], TODAY()))' />
      </column>
      <column caption='Age (from DOB' datatype='integer' name='[Calculation_2669902783877123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;, [DOB], TODAY())' />
      </column>
      <column caption='Attrition Flag ' datatype='integer' name='[Calculation_2669902784024580]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [EmployeeStatus] = &quot;Voluntarily Terminated&quot; OR [EmployeeStatus] = &quot;Terminated for Cause&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Department Type' datatype='string' name='[DepartmentType]' role='dimension' type='nominal' />
      <column caption='Emp ID' datatype='integer' name='[EmpID]' role='dimension' type='ordinal' />
